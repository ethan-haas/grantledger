# GrantLedger Environment Variables
# Copy this file to .env.local and fill in the values.
#
# Required: These must be set for the app to start.
# Optional: These have defaults and can be omitted for local development.

# ── Clerk Authentication (required) ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_monthly   # optional — defaults to price_monthly
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=price_annual      # optional — defaults to price_annual

# ── OpenAI (required) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Resend / Email (required) ───────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@grantledger.com             # optional — defaults to noreply@grantledger.com
RESEND_AUDIENCE_ID=                                    # optional — for newsletter subscriber list
CONTACT_EMAIL=support@grantledger.com                  # optional — defaults to support@grantledger.com

# ── Token Encryption (required) ─────────────────────────────────────────────
# 64-char hex string for encrypting OAuth tokens at rest.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Cron Jobs (required) ────────────────────────────────────────────────────
# Secret for authenticating Vercel cron job requests.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── App URL (optional) ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── PostHog Analytics (optional) ────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# ── Sentry Error Tracking (optional) ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=
SENTRY_PROJECT=

# ── QuickBooks Online (optional) ────────────────────────────────────────────
QBO_CLIENT_ID=...
QBO_CLIENT_SECRET=...

# ── Xero (optional) ─────────────────────────────────────────────────────────
XERO_CLIENT_ID=...
XERO_CLIENT_SECRET=...
